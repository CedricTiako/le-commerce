# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://lecommercetabac.test
APP_KEY=change-me-32-chars-random-string

# Base de données (accès Laragon par défaut)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=le_commerce
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Mail (formulaire de contact)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@lecommercetabac.fr
MAIL_FROM_NAME=Le Commerce

# Google
GOOGLE_PLACE_ID=

# WhatsApp Business API (lot back-office)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
